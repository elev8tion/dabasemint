{
  "build": {
    "beforeDevCommand": "npm run serve",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:4174",
    "distDir": "../dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "dabasemint",
    "version": "0.2.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": ["$HOME/**", "$APPDATA/**"]
      },
      "path": {
        "all": true
      },
      "shell": {
        "all": false
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.dabasemint.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [
        "../agent-proxy.mjs",
        "../src/agent-provider.mjs",
        "../src/agent-touchpoints.mjs"
      ]
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "dabasemint",
        "width": 1400,
        "minWidth": 900,
        "minHeight": 700
      }
    ]
  }
}